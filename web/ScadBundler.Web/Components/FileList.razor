@inject WorkspaceController Controller

@if (Analysis is { } analysis)
{
    <section class="filelist">
        <h2>Files</h2>

        @if (analysis.Root is null)
        {
            @if (analysis.EntryPointCandidates.Count > 0)
            {
                <p class="filelist-hint">Which file is your model? (The others look like libraries.)</p>
                <ul class="candidates">
                    @foreach (string candidate in analysis.EntryPointCandidates)
                    {
                        <li class="file">
                            <button type="button" class="link make-main"
                                    @onclick="@(() => Controller.SetRoot(candidate))">★ use as main</button>
                            <span class="icon loaded" role="img" aria-label="loaded" title="loaded">✓</span> @Display(candidate)
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="filelist-hint">Drop a <code>.scad</code> file to begin.</p>
            }
        }
        else
        {
            <ul>
                @foreach (ClassifiedFile file in Classified)
                {
                    <li class="file @UsageClass(file.Usage)">
                        @if (file.Usage == FileUsage.Root)
                        {
                            <span class="badge" title="main file">★ main</span>
                        }
                        else
                        {
                            <button type="button" class="link make-main" title="make this the main file"
                                    @onclick="@(() => Controller.SetRoot(file.VirtualPath))">★ make main</button>
                        }
                        <span class="icon @IconClass(file.Usage)" role="img" aria-label="@UsageTitle(file.Usage)" title="@UsageTitle(file.Usage)">@IconChar(file.Usage)</span>
                        @Display(file.VirtualPath)
                        @if (file.Usage == FileUsage.Unused)
                        {
                            <span class="tag-unused">unused</span>
                        }
                    </li>
                }
                @foreach (string font in Fonts)
                {
                    <li class="file font"><span class="icon font" role="img" aria-label="font" title="font">ⓕ</span> @font</li>
                }
            </ul>
        }

        @if (analysis.Missing.Count > 0 || analysis.Ambiguous.Count > 0)
        {
            <h3 class="needed-heading">Still needed</h3>
            @if (analysis.Missing.Count > 0)
            {
                <ul class="needed">
                    @foreach (MissingReference missing in analysis.Missing)
                    {
                        <MissingRow Missing="missing" @key="@($"{missing.RawPath}|{missing.Origin}")" />
                    }
                </ul>
            }
            @foreach (AmbiguousReference ambiguous in analysis.Ambiguous)
            {
                <ConflictPicker Ambiguous="ambiguous" @key="@($"{ambiguous.RawPath}|{ambiguous.Origin}")" />
            }
        }
    </section>
}

@code {
    /// <summary>The analysis to display; <c>null</c> renders nothing.</summary>
    [Parameter]
    public ProjectAnalysis? Analysis { get; set; }

    /// <summary>The uploaded set, for used/unused classification of the file rows.</summary>
    [Parameter]
    public IReadOnlyList<UploadedFile>? Uploads { get; set; }

    // Every uploaded file, labelled root / used / unused against the current dependency tree.
    private IReadOnlyList<ClassifiedFile> Classified =>
        Analysis is { } analysis ? FileClassifier.Classify(Uploads ?? [], analysis) : [];

    // The distinct font pass-throughs of the dependency tree, in walk order (fonts are not uploads).
    private IReadOnlyList<string> Fonts
    {
        get
        {
            var fonts = new List<string>();
            if (Analysis?.Tree is { } tree)
            {
                CollectFonts(tree.Root, fonts, []);
            }

            return fonts;
        }
    }

    private static void CollectFonts(DependencyNode node, List<string> fonts, HashSet<string> seen)
    {
        if (node.Origin == ReferenceOrigin.Font)
        {
            if (!fonts.Contains(node.VirtualPath))
            {
                fonts.Add(node.VirtualPath);
            }

            return;
        }

        if (!node.Resolved)
        {
            return;
        }

        foreach (DependencyNode child in node.Children)
        {
            CollectFonts(child, fonts, seen);
        }
    }

    private static string UsageClass(FileUsage usage) => usage switch
    {
        FileUsage.Root => "root",
        FileUsage.Unused => "unused",
        _ => string.Empty,
    };

    private static string IconClass(FileUsage usage) => usage == FileUsage.Unused ? "muted" : "loaded";

    private static string IconChar(FileUsage usage) => usage == FileUsage.Unused ? "○" : "✓";

    private static string UsageTitle(FileUsage usage) => usage switch
    {
        FileUsage.Root => "main file",
        FileUsage.Used => "loaded",
        _ => "uploaded but not used by the main file",
    };

    // Strip the synthetic "/proj/" project root for a maker-friendly display name.
    private static string Display(string virtualPath) =>
        virtualPath.StartsWith("/proj/", StringComparison.Ordinal) ? virtualPath["/proj/".Length..] : virtualPath;
}
