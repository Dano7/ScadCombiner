@implements IDisposable
@inject WorkspaceController Controller

<div class="page">
    <Landing />
    <EngineStatus />

    <DropZone />

    @if (Controller.Analysis is not null)
    {
        <StructureTree Uploads="Controller.Uploads" />

        <FileList Analysis="Controller.Analysis" Uploads="Controller.Uploads" />

        <MainFileEditor Root="@Controller.Root" RootText="@Controller.RootText" />

        @if (Controller.Root is not null && Controller.Bundle is null)
        {
            <p class="still-need">@StillNeedMessage</p>
        }

        <ProblemsPanel Diagnostics="CurrentDiagnostics" />
    }

    <OutputPanel Result="Controller.Bundle" RootPath="@Controller.Root" />

    @if (Controller.Analysis is not null)
    {
        <OptionsPanel />
    }
</div>

@code {
    // The richest diagnostics available: the full-pipeline bundle diagnostics when a bundle exists, else the
    // analysis's parse/semantic diagnostics. Both already have SB4001 filtered (the ProblemsPanel re-filters
    // it defensively).
    private IReadOnlyList<DiagnosticDto>? CurrentDiagnostics =>
        Controller.Bundle?.Diagnostics ?? Controller.Analysis?.Diagnostics;

    private string StillNeedMessage
    {
        get
        {
            int needed = (Controller.Analysis?.Missing.Count ?? 0) + (Controller.Analysis?.Ambiguous.Count ?? 0);
            return needed == 1
                ? "Still need 1 file before this project can be bundled."
                : $"Still need {needed} files before this project can be bundled.";
        }
    }

    protected override void OnInitialized() => Controller.Changed += OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Controller.Changed -= OnChanged;
}
